MUSIC_PROVIDER=acemusic-api
ACEMUSIC_API_BASE_URL=https://api.acemusic.ai
ACEMUSIC_API_KEY=replace_with_a_new_rotated_key
LOCAL_DAILY_LIMIT=0
LOCAL_BIND_HOST=127.0.0.1
LOCAL_API_PORT=4000
LOCAL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEPLOY_DEMO_ONLY=false
VITE_MUSIC_API_BASE=http://127.0.0.1:4000

# Hugging Face Docker Space:
# - add ACEMUSIC_API_KEY as a Space Secret, not as a public variable
# - the Space runtime provides PORT, but 7860 is the local Docker default
# - omit VITE_MUSIC_API_BASE in production so the frontend uses same-origin /api/*
# PORT=7860
# PUBLIC_APP_BASE_URL=
